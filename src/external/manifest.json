{
  "manifest_version": 3,
  "name": "FullFunnel HubSpot Audit (Free)",
  "version": "1.0.3",
  "description": "Free one-click HubSpot hygiene audit by FullFunnel — workflows, lists, properties, forms, flow maps + a cleanup plan, exported to Excel. Runs on your logged-in session.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "permissions": ["downloads", "storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.hubspot.com/*",
    "https://*.hubapi.com/*",
    "https://YOUR-N8N-HOST/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.hubspot.com/*"],
      "js": ["src/config.js", "src/diagnostics.js", "src/csv.js", "src/xlsx.js", "src/audit-properties.js", "src/audit-lists.js", "src/audit-forms.js", "src/audit-flowmaps.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
